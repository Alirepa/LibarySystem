@page "/books/{id:int}"
@using LibarySystem.Core
@using LibrarySystem.Web.Services
@inject BookService BookService
@inject LoanService LoanService
@inject MemberService MemberService
@inject NavigationManager Navigation

<PageTitle>@(book?.Title ?? "Bokdetaljer")</PageTitle>

<h1>Bokdetaljer</h1>

@if (book == null)
{
    <p>Laddar...</p>
}
else
{
    <div class="row">
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header">
                    <h5>@book.Title</h5>
                </div>
                <div class="card-body">
                    <p><strong>ISBN:</strong> @book.ISBN</p>
                    <p><strong>Författare:</strong> @book.Author</p>
                    <p><strong>Publiceringsår:</strong> @book.PublishedYear</p>
                    <p>
                        <strong>Status:</strong>
                        @if (book.IsAvailable)
                        {
                            <span class="badge bg-success">Tillgänglig</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Utlånad</span>
                        }
                    </p>

                    @if (!string.IsNullOrEmpty(message))
                    {
                        <div class="alert @(isError ? "alert-danger" : "alert-success")">@message</div>
                    }

                    @if (book.IsAvailable)
                    {
                        <div class="mt-3">
                            <h6>Låna denna bok</h6>
                            <div class="mb-3">
                                <label class="form-label">Välj medlem:</label>
                                <select @bind="selectedMemberId" class="form-control">
                                    <option value="">-- Välj medlem --</option>
                                    @foreach (var member in members)
                                    {
                                        <option value="@member.MemberId">@member.Name (@member.MemberId)</option>
                                    }
                                </select>
                            </div>
                            <button class="btn btn-success" @onclick="BorrowBook" disabled="@(string.IsNullOrEmpty(selectedMemberId))">
                                Låna bok
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="mt-3">
                            <button class="btn btn-warning" @onclick="ReturnBook">
                                Returnera bok
                            </button>
                        </div>
                    }

                    <div class="mt-3">
                        <a href="/books" class="btn btn-secondary">Tillbaka till lista</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- NY DEL: Lånehistorik -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>Lånehistorik</h5>
                </div>
                <div class="card-body">
                    @if (loanHistory == null)
                    {
                        <p>Laddar lånehistorik...</p>
                    }
                    else if (!loanHistory.Any())
                    {
                        <p>Ingen lånehistorik för denna bok.</p>
                    }
                    else
                    {
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Lånedatum</th>
                                    <th>Låntagare</th>
                                    <th>Återlämnad</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var loan in loanHistory)
                                {
                                    <tr>
                                        <td>@loan.LoanDate.ToString("yyyy-MM-dd")</td>
                                        <td>@loan.Member?.Name</td>
                                        <td>
                                            @if (loan.IsReturned)
                                            {
                                                @loan.ReturnDate?.ToString("yyyy-MM-dd")
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>
                                            @if (loan.IsReturned)
                                            {
                                                <span class="badge bg-secondary">Returnerad</span>
                                            }
                                            else if (loan.IsOverdue)
                                            {
                                                <span class="badge bg-danger">Försenad</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning">Pågående</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Book? book;
    private List<Member> members = new();
    private List<Loan>? loanHistory;
    private string? selectedMemberId;
    private string? message;
    private bool isError;

    protected override async Task OnInitializedAsync()
    {
        await LoadBook();
        await LoadMembers();
        await LoadLoanHistory();
    }

    private async Task LoadBook()
    {
        book = await BookService.GetBookByIdAsync(Id);
    }

    private async Task LoadMembers()
    {
        members = await MemberService.GetAllMembersAsync();
    }

    private async Task LoadLoanHistory()
    {
        var allLoans = await LoanService.GetAllLoansAsync();
        loanHistory = allLoans
            .Where(l => l.BookId == Id)
            .OrderByDescending(l => l.LoanDate)
            .ToList();
    }

    private async Task BorrowBook()
    {
        if (book == null || string.IsNullOrEmpty(selectedMemberId)) return;

        try
        {
            var loan = await LoanService.CreateLoanAsync(book.ISBN, selectedMemberId);

            if (loan != null)
            {
                message = $"Boken har lånats ut till {loan.Member?.Name}!";
                isError = false;
                selectedMemberId = "";
                await LoadBook(); // Ladda om boken
                await LoadLoanHistory(); // Ladda om historiken
            }
            else
            {
                message = "Kunde inte låna boken. Kontrollera att medlems-ID är korrekt.";
                isError = true;
            }
        }
        catch (Exception ex)
        {
            message = $"Ett fel uppstod: {ex.Message}";
            isError = true;
        }
    }

    private async Task ReturnBook()
    {
        if (book == null) return;

        try
        {
            var success = await LoanService.ReturnBookAsync(book.ISBN);

            if (success)
            {
                message = "Boken har returnerats!";
                isError = false;
                await LoadBook(); // Ladda om boken
                await LoadLoanHistory(); // Ladda om historiken
            }
            else
            {
                message = "Kunde inte returnera boken.";
                isError = true;
            }
        }
        catch (Exception ex)
        {
            message = $"Ett fel uppstod: {ex.Message}";
            isError = true;
        }
    }
}